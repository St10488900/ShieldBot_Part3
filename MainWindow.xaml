<Window x:Class="CyberAwarenessBot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ShieldBot — Cybersecurity AI"
        Height="820" Width="1140"
        MinHeight="660" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource MainBg}"
        FontFamily="Segoe UI">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="256"/>   <!-- Sidebar -->
            <ColumnDefinition Width="*"/>     <!-- Main -->
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════════════════ SIDEBAR ══ -->
        <Border Grid.Column="0"
                Background="{StaticResource SidebarBg}">
            <DockPanel>

                <!-- Top brand -->
                <Border DockPanel.Dock="Top" Padding="16,20,16,12">
                    <StackPanel Orientation="Horizontal">
                        <Viewbox Width="26" Height="26" Margin="0,0,10,0">
                            <Canvas Width="26" Height="26">
                                <Path Data="M13,1 L24,5.5 L24,12 C24,19 19,23 13,25 C7,23 2,19 2,12 L2,5.5 Z"
                                      Fill="#10A37F"/>
                                <Path Data="M8,13 L11,16.5 L18,9" Stroke="White" StrokeThickness="2"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round" Fill="Transparent"/>
                            </Canvas>
                        </Viewbox>
                        <StackPanel>
                            <TextBlock Text="ShieldBot"
                                       Foreground="White"
                                       FontFamily="Segoe UI Semibold"
                                       FontSize="15"/>
                            <TextBlock Text="Cybersecurity AI"
                                       Foreground="{StaticResource SidebarMuted}"
                                       FontSize="10.5"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Sidebar divider -->
                <Border DockPanel.Dock="Top" Height="1"
                        Background="{StaticResource SidebarBorder}" Margin="16,0"/>

                <!-- Session info bottom -->
                <Border DockPanel.Dock="Bottom"
                        BorderBrush="{StaticResource SidebarBorder}"
                        BorderThickness="0,1,0,0"
                        Padding="16,14">
                    <StackPanel>
                        <TextBlock Text="SESSION"
                                   Foreground="{StaticResource SidebarMuted}"
                                   FontSize="10" FontFamily="Segoe UI Semibold"
                                   Margin="0,0,0,8"/>
                        <TextBlock x:Name="TxtUserName"
                                   Text="User: —"
                                   Foreground="{StaticResource SidebarText}"
                                   FontSize="12.5" TextWrapping="Wrap"/>
                        <TextBlock x:Name="TxtUserTopic"
                                   Text="Topic: —"
                                   Foreground="{StaticResource SidebarMuted}"
                                   FontSize="12" TextWrapping="Wrap" Margin="0,3,0,0"/>
                        <TextBlock x:Name="TxtSentiment"
                                   Text="Mood: neutral"
                                   Foreground="{StaticResource SidebarMuted}"
                                   FontSize="12" Margin="0,3,0,0"/>
                        <Button Content="▶  Play greeting"
                                Style="{StaticResource NavButton}"
                                Click="BtnPlayGreeting_Click"
                                Margin="0,10,0,0"
                                HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </Border>

                <!-- Nav + Quick topics -->
                <ScrollViewer DockPanel.Dock="Top" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8,14,8,8">

                        <!-- Navigation -->
                        <TextBlock Text="NAVIGATION"
                                   Foreground="{StaticResource SidebarMuted}"
                                   FontSize="10" FontFamily="Segoe UI Semibold"
                                   Margin="12,0,0,6"/>

                        <Button x:Name="BtnNavChat"
                                Content="💬  Chat"
                                Style="{StaticResource NavButtonActive}"
                                Click="BtnNavChat_Click"
                                HorizontalAlignment="Stretch"
                                Margin="0,2"/>
                        <Button x:Name="BtnNavTasks"
                                Content="✅  Tasks"
                                Style="{StaticResource NavButton}"
                                Click="BtnNavTasks_Click"
                                HorizontalAlignment="Stretch"
                                Margin="0,2"/>
                        <Button x:Name="BtnNavQuiz"
                                Content="🎮  Quiz"
                                Style="{StaticResource NavButton}"
                                Click="BtnNavQuiz_Click"
                                HorizontalAlignment="Stretch"
                                Margin="0,2"/>
                        <Button x:Name="BtnNavLog"
                                Content="📋  Activity Log"
                                Style="{StaticResource NavButton}"
                                Click="BtnNavLog_Click"
                                HorizontalAlignment="Stretch"
                                Margin="0,2"/>

                        <!-- Clear chat -->
                        <Button Content="🗑  Clear chat"
                                Style="{StaticResource NavButton}"
                                Click="BtnClearChat_Click"
                                HorizontalAlignment="Stretch"
                                Margin="0,2"/>

                        <!-- Divider -->
                        <Border Height="1" Background="{StaticResource SidebarBorder}" Margin="4,14,4,10"/>

                        <!-- Quick topics -->
                        <TextBlock Text="QUICK TOPICS"
                                   Foreground="{StaticResource SidebarMuted}"
                                   FontSize="10" FontFamily="Segoe UI Semibold"
                                   Margin="12,0,0,6"/>

                        <Button Content="🔑  Passwords"    Style="{StaticResource TopicChip}" Click="QuickTopic_Click" Tag="password"      HorizontalAlignment="Stretch" Margin="0,1"/>
                        <Button Content="🎣  Phishing"      Style="{StaticResource TopicChip}" Click="QuickTopic_Click" Tag="phishing"      HorizontalAlignment="Stretch" Margin="0,1"/>
                        <Button Content="🌐  Safe browsing" Style="{StaticResource TopicChip}" Click="QuickTopic_Click" Tag="safe browsing" HorizontalAlignment="Stretch" Margin="0,1"/>
                        <Button Content="⚠  Scams"          Style="{StaticResource TopicChip}" Click="QuickTopic_Click" Tag="scam"          HorizontalAlignment="Stretch" Margin="0,1"/>
                        <Button Content="🦠  Malware"        Style="{StaticResource TopicChip}" Click="QuickTopic_Click" Tag="malware"       HorizontalAlignment="Stretch" Margin="0,1"/>
                        <Button Content="🔒  Privacy"        Style="{StaticResource TopicChip}" Click="QuickTopic_Click" Tag="privacy"       HorizontalAlignment="Stretch" Margin="0,1"/>
                        <Button Content="🔐  2FA / MFA"      Style="{StaticResource TopicChip}" Click="QuickTopic_Click" Tag="2fa"           HorizontalAlignment="Stretch" Margin="0,1"/>
                        <Button Content="🔄  Updates"        Style="{StaticResource TopicChip}" Click="QuickTopic_Click" Tag="update"        HorizontalAlignment="Stretch" Margin="0,1"/>

                    </StackPanel>
                </ScrollViewer>

            </DockPanel>
        </Border>

        <!-- ════════════════════════════════════════════ MAIN CONTENT ══ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>    <!-- Panel content -->
                <RowDefinition Height="Auto"/> <!-- Input bar (chat only) -->
                <RowDefinition Height="Auto"/> <!-- Status bar -->
            </Grid.RowDefinitions>

            <!-- ══════════════════════════════════════ CHAT PANEL ══ -->
            <Border x:Name="ChatPanel" Grid.Row="0" Background="{StaticResource MainBg}" Visibility="Visible">
                <ScrollViewer x:Name="ChatScrollViewer"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="ChatMessages"
                                Orientation="Vertical"
                                MaxWidth="780"
                                HorizontalAlignment="Center"
                                Margin="0,24,0,24"/>
                </ScrollViewer>
            </Border>

            <!-- ══════════════════════════════════════ TASK PANEL ══ -->
            <Border x:Name="TaskPanel" Grid.Row="0" Background="{StaticResource MainBg}" Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- Panel header -->
                        <RowDefinition Height="Auto"/>  <!-- Add task form -->
                        <RowDefinition Height="*"/>     <!-- Task list -->
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0" Padding="36,24,36,16"
                            BorderBrush="{StaticResource Divider}" BorderThickness="0,0,0,1">
                        <TextBlock Text="Task Assistant"
                                   FontSize="20" FontFamily="Segoe UI Semibold"
                                   Foreground="{StaticResource TextMain}"/>
                    </Border>

                    <!-- Add task form -->
                    <Border Grid.Row="1" Padding="36,20,36,16"
                            Background="{StaticResource CardBg}"
                            BorderBrush="{StaticResource Divider}"
                            BorderThickness="0,0,0,1">
                        <StackPanel>
                            <TextBlock Text="Add New Task"
                                       FontSize="13" FontFamily="Segoe UI Semibold"
                                       Foreground="{StaticResource TextMain}"
                                       Margin="0,0,0,14"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBox x:Name="TxtTaskTitle"
                                         Grid.Column="0"
                                         Style="{StaticResource PanelInput}"
                                         Tag="Task title"/>
                                <TextBox x:Name="TxtTaskDesc"
                                         Grid.Column="2"
                                         Style="{StaticResource PanelInput}"
                                         Tag="Description"/>
                                <TextBox x:Name="TxtTaskReminder"
                                         Grid.Column="4"
                                         Style="{StaticResource PanelInput}"
                                         Tag="Reminder (e.g. in 3 days)"/>
                                <Button  x:Name="BtnAddTask"
                                         Grid.Column="6"
                                         Content="Add Task"
                                         Style="{StaticResource PrimaryButton}"
                                         Click="BtnAddTask_Click"
                                         Height="42"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Task list -->
                    <Border Grid.Row="2" Padding="36,20">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="Your Tasks"
                                       FontSize="13" FontFamily="Segoe UI Semibold"
                                       Foreground="{StaticResource TextMain}"
                                       Margin="0,0,0,12"/>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <ListBox x:Name="TaskListBox"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         SelectionChanged="TaskListBox_SelectionChanged">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding"     Value="0"/>
                                            <Setter Property="Margin"      Value="0,0,0,8"/>
                                            <Setter Property="Background"  Value="Transparent"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <Border x:Name="Bg"
                                                                Background="{StaticResource CardBg}"
                                                                BorderBrush="{StaticResource CardBorder}"
                                                                BorderThickness="1"
                                                                CornerRadius="8"
                                                                Padding="16,12">
                                                            <ContentPresenter/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsSelected" Value="True">
                                                                <Setter TargetName="Bg" Property="BorderBrush" Value="{StaticResource AccentGreen}"/>
                                                                <Setter TargetName="Bg" Property="Background" Value="#F0FBF8"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                </ListBox>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                </Grid>
            </Border>

            <!-- ══════════════════════════════════════ QUIZ PANEL ══ -->
            <Border x:Name="QuizPanel" Grid.Row="0" Background="{StaticResource MainBg}" Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel MaxWidth="680" HorizontalAlignment="Center" Margin="0,40,0,40">

                        <!-- Quiz header -->
                        <TextBlock Text="Cybersecurity Quiz"
                                   FontSize="22" FontFamily="Segoe UI Semibold"
                                   Foreground="{StaticResource TextMain}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,6"/>
                        <TextBlock x:Name="TxtQuizProgress"
                                   Text="Test your knowledge"
                                   FontSize="13" Foreground="{StaticResource TextMuted}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,36"/>

                        <!-- Start screen -->
                        <StackPanel x:Name="QuizStartScreen">
                            <Border Background="{StaticResource CardBg}"
                                    BorderBrush="{StaticResource CardBorder}"
                                    BorderThickness="1" CornerRadius="12"
                                    Padding="36,32">
                                <StackPanel>
                                    <TextBlock Text="13 questions covering:"
                                               FontSize="14" Foreground="{StaticResource TextMuted}"
                                               Margin="0,0,0,16"/>
                                    <TextBlock Text="• Phishing awareness&#x0a;• Password safety&#x0a;• Safe browsing&#x0a;• Social engineering&#x0a;• Two-factor authentication&#x0a;• Malware &amp; ransomware&#x0a;• Privacy settings&#x0a;• Data backup"
                                               FontSize="13.5" Foreground="{StaticResource TextMain}"
                                               LineHeight="24"/>
                                    <Button Content="Start Quiz"
                                            Style="{StaticResource PrimaryButton}"
                                            Click="BtnStartQuiz_Click"
                                            Width="160" Height="44"
                                            HorizontalAlignment="Left"
                                            Margin="0,28,0,0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Active question screen -->
                        <StackPanel x:Name="QuizQuestionScreen" Visibility="Collapsed">
                            <Border Background="{StaticResource CardBg}"
                                    BorderBrush="{StaticResource CardBorder}"
                                    BorderThickness="1" CornerRadius="12"
                                    Padding="32,28">
                                <StackPanel>
                                    <!-- Score tracker -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                        <TextBlock x:Name="TxtQuizScore"
                                                   Text="Score: 0"
                                                   FontSize="12" Foreground="{StaticResource AccentGreen}"
                                                   FontFamily="Segoe UI Semibold"/>
                                        <TextBlock Text="  ·  "
                                                   FontSize="12" Foreground="{StaticResource TextMuted}"/>
                                        <TextBlock x:Name="TxtQuizQuestionNum"
                                                   Text="Question 1 of 13"
                                                   FontSize="12" Foreground="{StaticResource TextMuted}"/>
                                    </StackPanel>

                                    <!-- Question text -->
                                    <TextBlock x:Name="TxtQuestion"
                                               Text=""
                                               FontSize="15.5"
                                               FontFamily="Segoe UI Semibold"
                                               Foreground="{StaticResource TextMain}"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,24"/>

                                    <!-- Multiple choice options -->
                                    <StackPanel x:Name="McOptions">
                                        <RadioButton x:Name="RbA" GroupName="Quiz" Margin="0,0,0,10" FontSize="13.5" Foreground="{StaticResource TextMain}" Cursor="Hand"/>
                                        <RadioButton x:Name="RbB" GroupName="Quiz" Margin="0,0,0,10" FontSize="13.5" Foreground="{StaticResource TextMain}" Cursor="Hand"/>
                                        <RadioButton x:Name="RbC" GroupName="Quiz" Margin="0,0,0,10" FontSize="13.5" Foreground="{StaticResource TextMain}" Cursor="Hand"/>
                                        <RadioButton x:Name="RbD" GroupName="Quiz" Margin="0,0,0,10" FontSize="13.5" Foreground="{StaticResource TextMain}" Cursor="Hand"/>
                                    </StackPanel>

                                    <!-- True/False options -->
                                    <StackPanel x:Name="TfOptions" Visibility="Collapsed">
                                        <RadioButton x:Name="RbTrue"  Content="True"  GroupName="QuizTF" Margin="0,0,0,10" FontSize="13.5" Foreground="{StaticResource TextMain}" Cursor="Hand"/>
                                        <RadioButton x:Name="RbFalse" Content="False" GroupName="QuizTF" Margin="0,0,0,10" FontSize="13.5" Foreground="{StaticResource TextMain}" Cursor="Hand"/>
                                    </StackPanel>

                                    <!-- Submit button -->
                                    <Button x:Name="BtnSubmitAnswer"
                                            Content="Submit Answer"
                                            Style="{StaticResource PrimaryButton}"
                                            Click="BtnSubmitAnswer_Click"
                                            Width="160" Height="42"
                                            HorizontalAlignment="Left"
                                            Margin="0,20,0,0"/>

                                    <!-- Feedback area (hidden until answered) -->
                                    <Border x:Name="FeedbackArea" Visibility="Collapsed"
                                            Margin="0,20,0,0" Padding="16,14"
                                            CornerRadius="8">
                                        <StackPanel>
                                            <TextBlock x:Name="TxtFeedbackResult"
                                                       FontSize="14" FontFamily="Segoe UI Semibold"
                                                       Margin="0,0,0,6"/>
                                            <TextBlock x:Name="TxtFeedbackExplanation"
                                                       FontSize="13" TextWrapping="Wrap"
                                                       Foreground="{StaticResource TextMain}"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Next button (hidden until answered) -->
                                    <Button x:Name="BtnNextQuestion"
                                            Content="Next Question →"
                                            Style="{StaticResource SecondaryButton}"
                                            Click="BtnNextQuestion_Click"
                                            Width="160" Height="42"
                                            HorizontalAlignment="Left"
                                            Margin="0,12,0,0"
                                            Visibility="Collapsed"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Results screen -->
                        <StackPanel x:Name="QuizResultsScreen" Visibility="Collapsed">
                            <Border Background="{StaticResource CardBg}"
                                    BorderBrush="{StaticResource CardBorder}"
                                    BorderThickness="1" CornerRadius="12"
                                    Padding="36,32">
                                <StackPanel>
                                    <TextBlock Text="Quiz Complete!"
                                               FontSize="20" FontFamily="Segoe UI Semibold"
                                               Foreground="{StaticResource TextMain}"
                                               Margin="0,0,0,16"/>
                                    <TextBlock x:Name="TxtFinalScore"
                                               FontSize="36" FontFamily="Segoe UI Semibold"
                                               Foreground="{StaticResource AccentGreen}"
                                               Margin="0,0,0,12"/>
                                    <TextBlock x:Name="TxtFinalMessage"
                                               FontSize="14" TextWrapping="Wrap"
                                               Foreground="{StaticResource TextMuted}"
                                               Margin="0,0,0,28"/>
                                    <Button Content="Retake Quiz"
                                            Style="{StaticResource SecondaryButton}"
                                            Click="BtnRetakeQuiz_Click"
                                            Width="140" Height="42"
                                            HorizontalAlignment="Left"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ══════════════════════════════════════ LOG PANEL ══ -->
            <Border x:Name="LogPanel" Grid.Row="0" Background="{StaticResource MainBg}" Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Padding="36,24,36,16"
                            BorderBrush="{StaticResource Divider}" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Activity Log"
                                       FontSize="20" FontFamily="Segoe UI Semibold"
                                       Foreground="{StaticResource TextMain}"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtLogCount"
                                       Text=""
                                       FontSize="12" Foreground="{StaticResource TextMuted}"
                                       VerticalAlignment="Center" Margin="14,0,0,0"/>
                        </StackPanel>
                    </Border>

                    <ScrollViewer Grid.Row="1" Padding="36,20" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock x:Name="TxtLogEntries"
                                       FontSize="13" FontFamily="Cascadia Mono, Consolas, Courier New"
                                       Foreground="{StaticResource TextMain}"
                                       TextWrapping="Wrap"
                                       LineHeight="22"/>
                        </StackPanel>
                    </ScrollViewer>

                    <Border Grid.Row="2" Padding="36,14"
                            BorderBrush="{StaticResource Divider}" BorderThickness="0,1,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="BtnShowMore"
                                    Content="Show Full Log"
                                    Style="{StaticResource SecondaryButton}"
                                    Click="BtnShowMoreLog_Click"
                                    Visibility="Collapsed"
                                    Margin="0,0,12,0"/>
                            <Button Content="Refresh"
                                    Style="{StaticResource SecondaryButton}"
                                    Click="BtnRefreshLog_Click"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- ══════════════════════════════════════ TASK action bar (shown when task selected) ══ -->
            <!-- (Handled in code-behind, rendered inside task list items) -->

            <!-- ══════════════════════════════════════ INPUT BAR ══ -->
            <Border x:Name="InputBar" Grid.Row="1"
                    Background="White"
                    BorderBrush="{StaticResource Divider}"
                    BorderThickness="0,1,0,0"
                    Padding="0,14,0,14">
                <Grid MaxWidth="780" HorizontalAlignment="Center" Margin="24,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="TxtInput"
                             Grid.Column="0"
                             Style="{StaticResource ChatInput}"
                             KeyDown="TxtInput_KeyDown"
                             TextChanged="TxtInput_TextChanged"/>

                    <Button x:Name="BtnSend"
                            Grid.Column="2"
                            Content="Send"
                            Style="{StaticResource PrimaryButton}"
                            Click="BtnSend_Click"
                            Width="90" Height="44"/>
                </Grid>
            </Border>

            <!-- ══════════════════════════════════════ STATUS BAR ══ -->
            <Border Grid.Row="2"
                    Background="{StaticResource CardBg}"
                    BorderBrush="{StaticResource Divider}"
                    BorderThickness="0,1,0,0"
                    Padding="24,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="TxtStatus"
                               Grid.Column="0"
                               Text="Ready"
                               Foreground="{StaticResource TextMuted}"
                               FontSize="11.5" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1"
                               Text="Press Enter to send"
                               Foreground="{StaticResource TextMuted}"
                               FontSize="11.5" VerticalAlignment="Center"/>
                </Grid>
            </Border>

        </Grid>
    </Grid>
</Window>
